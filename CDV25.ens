; =========================
; macros
; =========================

PUSH: MACRO(reg)
        subu    r30, r30, 4 ; 1. Hacer hueco (bajar 4 escalones)
        st      reg, r30, 0 ; 2. Guardar el dato en el nuevo hueco
ENDMACRO

POP: MACRO(reg)
        ld      reg, r30, 0 ; 1. Recuperar el dato
        addu    r30, r30, 4 ; 2. Cerrar el hueco (subir 4 escalones)
ENDMACRO

LEA: MACRO(reg, etq) ;Load Effective Address = Dame la dirección postal
        or      reg, r0, low(etq) ; 1. Pega la mitad baja
        or.u    reg, reg, high(etq ) ; 2. Pega la mitad alta
ENDMACRO

LOAD: MACRO(reg, etq) ;Dame el contenido de esa dirección = Abre el buzón
        or      reg, r0, low(etq)
        or.u    reg, reg, high(etq) ; hasta aqui es lo mismo que el macro LEA
        ld      reg, reg, 0 ; Aqui carga en reg los contenidos que hay en la direccion reg 
ENDMACRO



; =========================
; pruebas que hemos ido usando
; =========================
; LongCad: "Prueba\0" -> 6
; BuscaCar: busca '*' en "*2345*78*0\0" desde 4 hasta 10 -> 5
; CoincidenCad: "abcde\0" con "abcXX\0" -> 3
; PoneBitA1: mapa 0x00, bit 3 -> 0x10
; LeeBit: mapa 0x54, bit 3 -> 1 y bit 4 -> 0
; Descomprime: caso sin referencias y caso largo de "tres tristes..."
; Comprime: "0123456789\0" -> tam 0x10 y caso largo -> tam 0x46
; Verifica: texto largo -> 0, long1 = long2 = 0x44

; =========================
; datos prueba 
; =========================


    org 0x8000

TXT1:
        data "tres tristes tigres comen trigo en un trigal, el primer tigre que...\0"

    org 0x8100

LONG1:
        data 0

LONG2:
        data 0

; =========================
; programa principal
; =========================
  org 0x8400

ppal:
        or      r30, r0, 0xF000      ; pila
        or      r31, r30, r30        ; fp

        LEA     (r10, TXT1)          ; texto
        LEA     (r11, LONG1)         ; long original
        LEA     (r12, LONG2)         ; long final

        PUSH    (r12)                ; Long2
        PUSH    (r11)                ; Long1
        PUSH    (r10)                ; texto
        bsr     Verifica

        addu    r30, r30, 12         ; quito parametros

        stop


; =========================
; subrutinas
; =========================
; LongCad: Cuenta los caracteres de una cadena hasta encontrar un \0

LongCad: 
        PUSH    (r1)
        PUSH    (r31)
        or      r31, r30, 0          ; nuevo fp

        ld      r10, r31, 8          ; cadena
        or      r29, r0, 0           ; contador

BucLC:
        ld.bu   r11, r10, r29        ; cadena[contador]
        cmp     r12, r11, 0
        bb1     eq, r12, FinLC       ; si es 0, fin

        addu    r29, r29, 1          ; contador++
        br      BucLC

FinLC:
        or      r30, r31, 0
        POP     (r31)
        POP     (r1)
        jmp     (r1)






;=======BUSCARCAR
BuscaCar:
        PUSH    (r1)
        PUSH    (r31)
        or      r31, r30, 0          ; fp fijo

        ld      r10, r31, 8          ; C
        ld      r11, r31, 12         ; ref
        ld      r12, r31, 16         ; i = from
        ld      r13, r31, 20         ; to

BucBC:
        cmp     r5, r12, r13
        bb1     hs, r5, NoBC         ; si i >= to

        ld.bu   r14, r11, r12        ; ref[i]
        cmp     r5, r14, r10
        bb1     eq, r5, SiBC         ; encontrado

        addu    r12, r12, 1          ; i++
        br      BucBC

SiBC:
        or      r29, r12, r12        ; retorno = i
        br      FinBC

NoBC:
        or      r29, r13, r13        ; retorno = to

FinBC:
        or      r30, r31, 0
        POP     (r31)
        POP     (r1)
        jmp     (r1)

;-----------

CoincidenCad:
        PUSH    (r1)
        PUSH    (r31)
        or      r31, r30, 0          ; fp fijo

        ld      r10, r31, 8          ; cad1
        ld      r11, r31, 12         ; cad2
        or      r29, r0, 0           ; contador

BucCC:
        ld.bu   r12, r10, r29        ; cad1[i]
        ld.bu   r13, r11, r29        ; cad2[i]

        cmp     r5, r12, r13
        bb1     ne, r5, FinCC        ; si son distintos

        cmp     r5, r12, 0
        bb1     eq, r5, FinCC        ; si llego a fin

        addu    r29, r29, 1          ; contador++
        br      BucCC

FinCC:
        or      r30, r31, 0
        POP     (r31)
        POP     (r1)
        jmp     (r1)
;---------


PoneBitA1:
        PUSH    (r1)
        PUSH    (r31)
        or      r31, r30, 0          ; fp fijo

        ld      r10, r31, 8          ; dir mapa
        ld      r11, r31, 12         ; num bit

        divu    r12, r11, 8          ; byte = numbit / 8
        mulu    r13, r12, 8
        subu    r14, r11, r13        ; resto = numbit % 8

        or      r15, r0, 0x80        ; mascara inicial

BucPBA1:
        cmp     r5, r14, 0
        bb1     eq, r5, FinBucPBA1

        divu    r15, r15, 2          ; mascara / 2
        subu    r14, r14, 1
        br      BucPBA1

FinBucPBA1:
        ld.bu   r16, r10, r12        ; byte actual
        or      r16, r16, r15        ; pongo bit a 1
        st.b    r16, r10, r12        ; guardo byte

        or      r30, r31, 0
        POP     (r31)
        POP     (r1)
        jmp     (r1)
;----- COMPRIME--------------

Comprime:
        PUSH    (r1)
        PUSH    (r31)
        or      r31, r30, 0          ; fp fijo

        ld      r10, r31, 8          ; texto
        ld      r11, r31, 12         ; comprdo

        subu    r30, r30, 4          ; local P
        or      r19, r30, 0          ; dir P

        PUSH    (r10)
        bsr     LongCad
        addu    r30, r30, 4

        ld      r10, r31, 8          ; texto
        ld      r11, r31, 12         ; comprdo
        or      r12, r29, r29        ; long texto

        addu    r13, r12, 3          ; ajustar a mult 4
        divu    r13, r13, 4
        mulu    r13, r13, 4

        subu    r30, r30, r13        ; zona3 temporal
        or      r18, r30, 0          ; dir zona3 temp

        addu    r17, r11, 5          ; mapa bits

        or      r14, r0, 0           ; pos texto
        or      r15, r0, 0           ; pos zona3
        or      r16, r0, 0           ; num bit

CopIniC:
        cmp     r5, r14, r12
        bb1     hs, r5, FinBuildC

        cmp     r5, r14, 8
        bb1     hs, r5, BucC

        ld.bu   r21, r10, r14
        st.b    r21, r18, r15

        addu    r14, r14, 1
        addu    r15, r15, 1
        br      CopIniC

BucC:
        cmp     r5, r14, r12
        bb1     hs, r5, FinBuildC

        divu    r22, r16, 8          ; byte mapa
        mulu    r23, r22, 8
        subu    r24, r16, r23        ; resto bit

        cmp     r5, r24, 0
        bb1     ne, r5, NoInitMC

        or      r25, r0, 0
        st.b    r25, r17, r22        ; nuevo byte mapa a 0

NoInitMC:
        PUSH    (r10)
        PUSH    (r11)
        PUSH    (r12)
        PUSH    (r13)
        PUSH    (r14)
        PUSH    (r15)
        PUSH    (r16)
        PUSH    (r17)
        PUSH    (r18)
        PUSH    (r19)

        PUSH    (r19)                ; dir P
        PUSH    (r14)                ; max
        PUSH    (r10)                ; texto
        bsr     BuscaMax
        addu    r30, r30, 12         ; quito params

        POP     (r19)
        POP     (r18)
        POP     (r17)
        POP     (r16)
        POP     (r15)
        POP     (r14)
        POP     (r13)
        POP     (r12)
        POP     (r11)
        POP     (r10)

        or      r20, r29, r29        ; L
        ld      r24, r19, 0          ; P

        cmp     r5, r20, 4
        bb1     lt, r5, LitC

RefC:
        PUSH    (r10)
        PUSH    (r11)
        PUSH    (r12)
        PUSH    (r13)
        PUSH    (r14)
        PUSH    (r15)
        PUSH    (r16)
        PUSH    (r17)
        PUSH    (r18)
        PUSH    (r19)
        PUSH    (r20)
        PUSH    (r24)

        PUSH    (r16)                ; num bit
        PUSH    (r17)                ; mapa
        bsr     PoneBitA1
        addu    r30, r30, 8

        POP     (r24)
        POP     (r20)
        POP     (r19)
        POP     (r18)
        POP     (r17)
        POP     (r16)
        POP     (r15)
        POP     (r14)
        POP     (r13)
        POP     (r12)
        POP     (r11)
        POP     (r10)

        divu    r25, r24, 256        ; P high
        mulu    r26, r25, 256
        subu    r21, r24, r26        ; P low

        st.b    r21, r18, r15        ; P low
        addu    r15, r15, 1
        st.b    r25, r18, r15        ; P high
        addu    r15, r15, 1
        st.b    r20, r18, r15        ; L
        addu    r15, r15, 1

        addu    r14, r14, r20        ; avanzo L chars
        addu    r16, r16, 1          ; siguiente bit
        br      BucC

LitC:
        ld.bu   r21, r10, r14
        st.b    r21, r18, r15

        addu    r14, r14, 1
        addu    r15, r15, 1
        addu    r16, r16, 1
        br      BucC

FinBuildC:
        addu    r22, r16, 7          ; bytes mapa
        divu    r22, r22, 8

        divu    r25, r12, 256        ; long high
        mulu    r26, r25, 256
        subu    r21, r12, r26        ; long low

        st.b    r21, r11, 0
        st.b    r25, r11, 1

        or      r21, r0, 1
        st.b    r21, r11, 2          ; M

        addu    r23, r22, 5          ; offset zona3

        divu    r25, r23, 256
        mulu    r26, r25, 256
        subu    r21, r23, r26

        st.b    r21, r11, 3          ; offset low
        st.b    r25, r11, 4          ; offset high

        addu    r24, r11, r23        ; destino zona3
        or      r25, r0, 0           ; i copia

CopZona3C:
        cmp     r5, r25, r15
        bb1     hs, r5, FinC

        ld.bu   r21, r18, r25
        st.b    r21, r24, r25

        addu    r25, r25, 1
        br      CopZona3C

FinC:
        addu    r29, r23, r15        ; tam total

        or      r30, r31, 0
        POP     (r31)
        POP     (r1)
        jmp     (r1)


;------------------------
LeeBit:
        PUSH    (r1)
        PUSH    (r31)
        or      r31, r30, 0          ; fp fijo

        ld      r10, r31, 8          ; dir mapa
        ld      r11, r31, 12         ; num bit

        divu    r12, r11, 8          ; byte = numbit / 8
        mulu    r13, r12, 8
        subu    r14, r11, r13        ; resto = numbit % 8

        or      r15, r0, 0x80        ; mascara inicial

BucLB:
        cmp     r5, r14, 0
        bb1     eq, r5, FinBucLB

        divu    r15, r15, 2          ; mascara / 2
        subu    r14, r14, 1
        br      BucLB

FinBucLB:
        ld.bu   r16, r10, r12        ; byte actual
        and     r17, r16, r15        ; miro el bit

        cmp     r5, r17, 0
        bb1     eq, r5, CeroLB

        or      r29, r0, 1           ; bit = 1
        br      FinLB

CeroLB:
        or      r29, r0, 0           ; bit = 0

FinLB:
        or      r30, r31, 0
        POP     (r31)
        POP     (r1)
        jmp     (r1)
;-------------
Descomprime:
        PUSH    (r1)
        PUSH    (r31)
        or      r31, r30, 0          ; fp fijo

        ld      r10, r31, 8          ; com
        ld      r11, r31, 12         ; desc

        ld.bu   r12, r10, 0          ; long low
        ld.bu   r13, r10, 1          ; long high
        mulu    r13, r13, 256
        addu    r12, r12, r13        ; longitud original

        ld.bu   r14, r10, 2          ; M
        mulu    r14, r14, 8          ; 8*M

        ld.bu   r15, r10, 3          ; zona3 low
        ld.bu   r13, r10, 4          ; zona3 high
        mulu    r13, r13, 256
        addu    r15, r15, r13        ; offset zona3

        addu    r16, r10, 5          ; mapa bits
        addu    r17, r10, r15        ; zona3

        or      r18, r0, 0           ; pos desc
        or      r19, r0, 0           ; pos zona3
        or      r20, r0, 0           ; num bit

CopIniD:
        cmp     r5, r18, r14
        bb1     hs, r5, BucD         ; ya copie 8*M

        cmp     r5, r18, r12
        bb1     hs, r5, FinD         ; texto corto

        ld.bu   r21, r17, r19        ; zona3[pos]
        st.b    r21, r11, r18        ; desc[pos]

        addu    r18, r18, 1
        addu    r19, r19, 1
        br      CopIniD

BucD:
        cmp     r5, r18, r12
        bb1     hs, r5, FinD         ; si pos >= long

        PUSH    (r10)
        PUSH    (r11)
        PUSH    (r12)
        PUSH    (r13)
        PUSH    (r14)
        PUSH    (r15)
        PUSH    (r16)
        PUSH    (r17)
        PUSH    (r18)
        PUSH    (r19)
        PUSH    (r20)

        PUSH    (r20)                ; num bit
        PUSH    (r16)                ; mapa
        bsr     LeeBit
        addu    r30, r30, 8          ; quito params LeeBit

        POP     (r20)
        POP     (r19)
        POP     (r18)
        POP     (r17)
        POP     (r16)
        POP     (r15)
        POP     (r14)
        POP     (r13)
        POP     (r12)
        POP     (r11)
        POP     (r10)

        cmp     r5, r29, 0
        bb1     eq, r5, LiteralD

RefD:
        ld.bu   r22, r17, r19        ; P low
        addu    r26, r19, 1
        ld.bu   r13, r17, r26        ; P high
        mulu    r13, r13, 256
        addu    r22, r22, r13        ; P

        addu    r26, r19, 2
        ld.bu   r23, r17, r26        ; L

        addu    r19, r19, 3          ; consumo referencia
        or      r24, r0, 0           ; k

BucRefD:
        cmp     r5, r24, r23
        bb1     hs, r5, FinRefD

        addu    r25, r22, r24        ; P+k
        ld.bu   r21, r11, r25        ; desc[P+k]
        st.b    r21, r11, r18        ; desc[pos]

        addu    r18, r18, 1
        addu    r24, r24, 1
        br      BucRefD

FinRefD:
        addu    r20, r20, 1
        br      BucD

LiteralD:
        ld.bu   r21, r17, r19        ; caracter
        st.b    r21, r11, r18

        addu    r18, r18, 1
        addu    r19, r19, 1
        addu    r20, r20, 1
        br      BucD

FinD:
        or      r21, r0, 0
        st.b    r21, r11, r18        ; \0

        or      r29, r12, r12        ; retorno = longitud

        or      r30, r31, 0
        POP     (r31)
        POP     (r1)
        jmp     (r1)
;----------------------

Verifica:
        PUSH    (r1)
        PUSH    (r31)
        or      r31, r30, 0          ; fp fijo

        subu    r30, r30, 16         ; locales

        ld      r10, r31, 8          ; texto
        PUSH    (r10)
        bsr     LongCad
        addu    r30, r30, 4

        st      r29, r31, -4         ; long original

        ld      r10, r31, 12         ; Long1
        st      r29, r10, 0

        ; tam comprimido aprox = long + bytes mapa + 5
        ld      r20, r31, -4
        addu    r21, r20, 7
        divu    r21, r21, 8          ; bytes mapa aprox
        addu    r22, r20, r21
        addu    r22, r22, 5
        addu    r22, r22, 3
        divu    r22, r22, 4
        mulu    r22, r22, 4          ; ajustado a 4

        subu    r30, r30, r22
        or      r23, r30, r30        ; pila comprimido
        st      r23, r31, -8

        ; tam descomprimido = long + \0, ajustado a 4
        ld      r20, r31, -4
        addu    r24, r20, 1
        addu    r24, r24, 3
        divu    r24, r24, 4
        mulu    r24, r24, 4

        subu    r30, r30, r24
        or      r25, r30, r30        ; pila descomprimido
        st      r25, r31, -12

        ; Comprime(texto, pila comprimido)
        ld      r10, r31, 8
        ld      r11, r31, -8

        PUSH    (r11)
        PUSH    (r10)
        bsr     Comprime
        addu    r30, r30, 8

        ; Descomprime(pila comprimido, pila descomprimido)
        ld      r10, r31, -8
        ld      r11, r31, -12

        PUSH    (r11)
        PUSH    (r10)
        bsr     Descomprime
        addu    r30, r30, 8

        ; guardo Long2
        ld      r10, r31, 16
        st      r29, r10, 0

        ; comparo longitudes
        ld      r20, r31, -4
        cmp     r5, r20, r29
        bb1     ne, r5, DifLongV

        ; comparo contenido
        ld      r10, r31, 8
        ld      r11, r31, -12

        PUSH    (r11)
        PUSH    (r10)
        bsr     CoincidenCad
        addu    r30, r30, 8

        ld      r20, r31, -4
        cmp     r5, r29, r20
        bb1     eq, r5, OkV

DifContV:
        sub     r29, r0, 2           ; -2 contenido distinto
        br      FinV

DifLongV:
        sub     r29, r0, 1           ; -1 longitudes distintas
        br      FinV

OkV:
        or      r29, r0, 0           ; correcto

FinV:
        or      r30, r31, 0
        POP     (r31)
        POP     (r1)
        jmp     (r1)



















































; =========================
; BuscaMax dada
; no tocar
; =========================

;
; Debe incorporar este fichero con TODAS sus l�neas, sin modificar
; ninguna de ellas, al final de su archivo CDV24.ens
;
; Este aviso se refiere tambi�n a las l�neas de comentario
; 
;
;; Grupo:    carlosyoan - Thu Jun 11 18:01:28 CEST 2026

BuscaMax:
	PUSH (r1)
	PUSH (r31)
	or   r31, r30, 0
	or   r28, r0, 0x1C8B
	PUSH (r28)

	ld   r10, r31, 8;  REF
	ld   r11, r31, 12; MAX
	ld   r12, r31, 16; Dir(JJ)

	sub  r5, r0, 1		; guarda -1 en *JJ por si no se
	st   r5, r12, 0		; encuentran coincidencias

	addu r27, r0, r0  ; P
	addu r28, r0, r0  ; L

BucBM:
	ld.bu r20, r10, r11	; C=REF(max)

				; Reserva registros que
				; necesita conservar
	PUSH (r28) 	    	; L
	PUSH (r11)	    	; MAX

	     		    	; Par�metros de BuscaCar
	PUSH (r27)	    	; P
	PUSH (r10)	    	; REF
	PUSH (r20)	   	; C
	bsr  BuscaCar
	POP  (r20)
	POP  (r10)
	POP  (r27)

	POP  (r11)		; Recupera registros
	POP  (r28)	        ; salvaguardados

	cmp  r5, r29, r11	; nuevo P es >= MAX ??
	bb1  hs, r5, finBM
	addu r27, r29, r0	; P = nuevo P
	
	addu r13, r10, r27	; *REF(P)
	addu r14, r10, r11 	; *REF(max)	

	PUSH (r11)     		; Reserva registros que
	PUSH (r10)		; necesita conservar
	PUSH (r28)
	PUSH (r27)
	
	PUSH (r14)		; Par�metros de CoincidenCad
	PUSH (r13)
	bsr  CoincidenCad
	POP  (r13)
	POP  (r14)
	
	POP  (r27)		; Recupera registros
	POP  (r28)		; salvaguardados
	POP  (r10)
	POP  (r11)

	cmp r5, r29, r28	; Comprueba si longitud > L
	bb1 le, r5, contBM	; Si no lo es, contin�a
	cmp r5, r29, 255	; Comprueba si longitud > 255
	bb1 le, r5, noLimBM	; Si no lo es, contin�a
	addu r29, r0, 255	; Si lo es, limita su valor a 255
	
noLimBM:
	addu r28, r29, r0	; actualiza L
	ld   r12, r31, 16	; Dir(JJ)
	st   r27, r12, r0	; actualiza P en *JJ
	bb1 ge, r5, finBM	; Si coincidencia >= 255 termina
contBM: 
	addu r27, r27, 1	; Pasa al siguiente car�cter
	cmp  r5, r27, r11	; Es P>=max ?
	bb1  hs, r5, finBM
	
	br   BucBM   		; Nueva b�squeda del primer car�cter

finBM:
	addu r29, r28, r0	; asigna L al valor de retorno r29
	  
	or   r27, r0, 0x6FE
	POP  (r28)

	or   r30, r31, 0
	POP  (r31)
	POP  (r1)
	jmp  (r1)
;; Grupo:    carlosyoan